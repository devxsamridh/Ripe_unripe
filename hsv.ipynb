import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import TensorDataset, DataLoader
import matplotlib.pyplot as plt

# ================= DEVICE =================
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print("Device:", device)

# ================= LOAD DATA =================
X_train = np.load(r"A:\VS-SIT\X_train.npy") / 255.0
y_train = np.load(r"A:\VS-SIT\y_train.npy")
X_test  = np.load(r"A:\VS-SIT\X_test.npy") / 255.0
y_test  = np.load(r"A:\VS-SIT\y_test.npy")

# Fix shape (N,H,W,C → N,C,H,W)
if len(X_train.shape) == 4 and X_train.shape[-1] == 3:
    X_train = np.transpose(X_train, (0, 3, 1, 2))
    X_test  = np.transpose(X_test, (0, 3, 1, 2))

# To tensor
X_train = torch.tensor(X_train, dtype=torch.float32)
X_test  = torch.tensor(X_test, dtype=torch.float32)
y_train = torch.tensor(y_train, dtype=torch.long)
y_test  = torch.tensor(y_test, dtype=torch.long)

train_loader = DataLoader(TensorDataset(X_train, y_train), batch_size=32, shuffle=True)
test_loader  = DataLoader(TensorDataset(X_test, y_test), batch_size=32)

num_classes = len(torch.unique(y_train))
print("Classes:", num_classes)

# ================= MODEL =================
class AttentionBlock(nn.Module):
    def __init__(self, channels):
        super().__init__()
        self.fc = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Flatten(),
            nn.Linear(channels, channels // 2),
            nn.ReLU(),
            nn.Linear(channels // 2, channels),
            nn.Sigmoid()
        )

    def forward(self, x):
        attn = self.fc(x).view(x.size(0), x.size(1), 1, 1)
        return x * attn

class FastCNN(nn.Module):
    def __init__(self, num_classes):
        super().__init__()

        self.conv = nn.Sequential(
            nn.Conv2d(3, 16, 3, padding=1),
            nn.BatchNorm2d(16),
            nn.ReLU(),
            nn.MaxPool2d(2),

            nn.Conv2d(16, 32, 3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(),
            nn.MaxPool2d(2)
        )

        self.attn_conv = nn.Conv2d(32, 64, 3, padding=1)
        self.attn_bn   = nn.BatchNorm2d(64)
        self.attn_relu = nn.ReLU()
        self.attn      = AttentionBlock(64)

        self.pool = nn.AdaptiveAvgPool2d((4, 4))

        self.fc = nn.Sequential(
            nn.Flatten(),
            nn.Linear(64 * 4 * 4, 128),
            nn.ReLU(),
            nn.Dropout(0.6),
            nn.Linear(128, num_classes)
        )

    def forward(self, x):
        x = self.conv(x)
        x = self.attn_relu(self.attn_bn(self.attn_conv(x)))
        x = self.attn(x)
        x = self.pool(x)
        return self.fc(x)

model = FastCNN(num_classes).to(device)

# ================= TRAIN =================
EPOCHS = 50
criterion = nn.CrossEntropyLoss()

# tuned optimizer (prevents explosion)
optimizer = optim.Adam(model.parameters(), lr=0.0005, weight_decay=1e-3)

scheduler = optim.lr_scheduler.StepLR(optimizer, step_size=15, gamma=0.5)

train_acc_hist, val_acc_hist = [], []
train_loss_hist, val_loss_hist = [], []

best_acc = 0
best_model = None

for epoch in range(EPOCHS):

    # ---- TRAIN ----
    model.train()
    correct, total, loss_sum = 0, 0, 0

    for X, y in train_loader:
        X, y = X.to(device), y.to(device)

        optimizer.zero_grad()
        out = model(X)
        loss = criterion(out, y)
        loss.backward()
        optimizer.step()

        _, pred = out.max(1)
        total += y.size(0)
        correct += (pred == y).sum().item()
        loss_sum += loss.item() * y.size(0)

    train_acc = correct / total
    train_loss = loss_sum / total

    # ---- VALIDATION ----
    model.eval()
    correct, total, loss_sum = 0, 0, 0

    with torch.no_grad():
        for X, y in test_loader:
            X, y = X.to(device), y.to(device)
            out = model(X)
            loss = criterion(out, y)

            _, pred = out.max(1)
            total += y.size(0)
            correct += (pred == y).sum().item()
            loss_sum += loss.item() * y.size(0)

    val_acc = correct / total
    val_loss = loss_sum / total

    scheduler.step()

    train_acc_hist.append(train_acc)
    val_acc_hist.append(val_acc)
    train_loss_hist.append(train_loss)
    val_loss_hist.append(val_loss)

    if val_acc > best_acc:
        best_acc = val_acc
        best_model = model.state_dict()

    print(f"Epoch [{epoch+1}/{EPOCHS}]  Train Loss={train_loss:.6f}  Val Loss={val_loss:.6f}")

print("Best Accuracy:", best_acc)

# ================= SAVE =================
torch.save(best_model, "best_model.pth")

# ================= PLOTS =================
epochs = range(1, EPOCHS + 1)

fig, axes = plt.subplots(1, 2, figsize=(14, 5))

# Accuracy
axes[0].plot(epochs, train_acc_hist, 'o-', label='Train Accuracy')
axes[0].plot(epochs, val_acc_hist, 's--', label='Validation Accuracy')
axes[0].set_title("Accuracy vs Epochs")
axes[0].set_xlabel("Epochs")
axes[0].set_ylabel("Accuracy")
axes[0].legend()
axes[0].grid(True, alpha=0.3)

# Loss (FIXED)
axes[1].plot(epochs, train_loss_hist, 'o-', label='Train Loss')
axes[1].plot(epochs, val_loss_hist, 's--', label='Validation Loss')
axes[1].set_title("Loss vs Epochs")
axes[1].set_xlabel("Epochs")
axes[1].set_ylabel("Loss")

# 🔥 critical fix
axes[1].set_yscale('log')

axes[1].legend()
axes[1].grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig("final_training_curves.png", dpi=150)
plt.show()
