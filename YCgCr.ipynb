import numpy as np
import cv2
import os
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow.keras.models import Sequential, load_model
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense
from tensorflow.keras.optimizers import Adam

DATA_DIR = '/content/drive/MyDrive/data'

X_train = np.load(os.path.join(DATA_DIR, 'X_train.npy'))
X_test  = np.load(os.path.join(DATA_DIR, 'X_test.npy'))
y_train = np.load(os.path.join(DATA_DIR, 'y_train.npy'))
y_test  = np.load(os.path.join(DATA_DIR, 'y_test.npy'))

print("X_train shape:", X_train.shape)
print("X_test shape :", X_test.shape)
print("y_train shape:", y_train.shape)
print("y_test shape :", y_test.shape)

def build_model():
    model = Sequential([
        Conv2D(32,  (3,3), activation='relu', input_shape=(100,100,3), padding='same'),
        MaxPooling2D((2,2)),
        Conv2D(64,  (3,3), activation='relu', padding='same'),
        MaxPooling2D((2,2)),
        Conv2D(128, (3,3), activation='relu', padding='same'),
        MaxPooling2D((2,2)),
        Conv2D(256, (3,3), activation='relu', padding='same'),
        MaxPooling2D((2,2)),
        Conv2D(512, (3,3), activation='relu', padding='same'),
        MaxPooling2D((2,2)),
        Flatten(),
        Dense(512, activation='relu'),
        Dense(1,   activation='sigmoid')
    ])
    model.compile(optimizer=Adam(), loss='binary_crossentropy', metrics=['accuracy'])
    return model

ycgcr_model = build_model()
ycgcr_model.summary()


import cv2
import numpy as np

# Based on error: dense layer expects 4608 features
# 4608 = 48 * 48 * 2 or depends on your conv/pool layers
# Use the shape from ycgcr_model.input_shape to get the exact target size

# Extract expected height and width from model
_, expected_h, expected_w, expected_c = ycgcr_model.input_shape
target_size = (expected_w, expected_h)  # cv2 uses (width, height)

print(f"Resizing images to: {target_size}")

# Resize train and test sets
X_train_resized = np.array([cv2.resize(img, target_size) for img in X_train])
X_test_resized  = np.array([cv2.resize(img, target_size) for img in X_test])

print("X_train_resized shape:", X_train_resized.shape)
print("X_test_resized shape:", X_test_resized.shape)

# Convert one-hot labels to binary (0 / 1)
import numpy as np
y_train = np.argmax(y_train, axis=1)
y_test = np.argmax(y_test, axis=1)

# Recompile model (IMPORTANT)
ycgcr_model.compile(
    optimizer='adam',
    loss='binary_crossentropy',
    metrics=['accuracy']
)

# Train model
ycgcr_history = ycgcr_model.fit(
    X_train_resized, y_train,
    epochs=50,
    validation_data=(X_test_resized, y_test),
    batch_size=32,
    verbose=1
)

# Save model
import os
os.makedirs('/content/drive/MyDrive/models', exist_ok=True)
ycgcr_model.save('/content/drive/MyDrive/models/arecanut_ycgcr_model.h5')

print("YCgCr model saved.")

